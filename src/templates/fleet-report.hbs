<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      font-size: 11px;
      color: #1a1a2e;
      background: #fff;
      padding: 30px 40px;
    }

    .header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-bottom: 3px solid #C8A951;
      padding-bottom: 15px;
      margin-bottom: 20px;
    }
    .header h1 {
      font-size: 22px;
      color: #003366;
      font-weight: 700;
    }
    .header .subtitle {
      font-size: 11px;
      color: #666;
      margin-top: 4px;
    }
    .header .logo {
      text-align: right;
    }
    .header .logo .brand {
      font-size: 18px;
      font-weight: 700;
      color: #C8A951;
    }
    .header .logo .brand-sub {
      font-size: 9px;
      color: #003366;
      font-weight: 600;
    }

    .fleet-info {
      background: #F5F2EB;
      border-radius: 8px;
      padding: 14px 20px;
      margin-bottom: 20px;
      display: flex;
      gap: 40px;
    }
    .fleet-info .label {
      font-size: 9px;
      text-transform: uppercase;
      color: #666;
      letter-spacing: 0.5px;
    }
    .fleet-info .value {
      font-size: 13px;
      font-weight: 600;
      color: #003366;
    }

    .section {
      margin-bottom: 18px;
      page-break-inside: avoid;
    }
    .section-title {
      font-size: 13px;
      font-weight: 700;
      color: #003366;
      border-left: 4px solid #C8A951;
      padding-left: 10px;
      margin-bottom: 10px;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 8px;
    }
    th {
      background: #003366;
      color: #fff;
      padding: 7px 10px;
      text-align: left;
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    td {
      padding: 6px 10px;
      border-bottom: 1px solid #e8ecf1;
      font-size: 11px;
    }
    tr:nth-child(even) { background: #f8f9fc; }

    .metric-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 10px;
    }
    .metric-card {
      background: #f8f9fc;
      border-radius: 6px;
      padding: 12px 14px;
      border-left: 3px solid #003366;
    }
    .metric-card .metric-label {
      font-size: 9px;
      text-transform: uppercase;
      color: #666;
    }
    .metric-card .metric-value {
      font-size: 20px;
      font-weight: 700;
      color: #003366;
      margin-top: 2px;
    }
    .metric-card .metric-unit {
      font-size: 9px;
      color: #999;
    }
    .metric-card.danger { border-left-color: #E5004B; }
    .metric-card.warning { border-left-color: #C8A951; }
    .metric-card.success { border-left-color: #2ecc71; }

    .highlight { background: #FFF8E1 !important; }

    .status-badge {
      display: inline-block;
      padding: 2px 8px;
      border-radius: 10px;
      font-size: 9px;
      font-weight: 600;
      text-transform: uppercase;
    }
    .status-overdue { background: #fde8ec; color: #E5004B; }
    .status-ok { background: #e8f8f0; color: #2ecc71; }

    .footer {
      margin-top: 30px;
      padding-top: 10px;
      border-top: 1px solid #C8A951;
      font-size: 9px;
      color: #999;
      text-align: center;
    }
  </style>
</head>
<body>

  <div class="header">
    <div>
      <h1>Fleet Performance Report</h1>
      <div class="subtitle">
        Reporting Period: {{formatDate period.startDate}} — {{formatDate period.endDate}}
      </div>
    </div>
    <div class="logo">
      <div class="brand">GOLDBELL</div>
      <div class="brand-sub">Engineering Services</div>
    </div>
  </div>

  <div class="fleet-info">
    <div class="field">
      <div class="label">Customer</div>
      <div class="value">{{customerName}}</div>
    </div>
    <div class="field">
      <div class="label">Customer Code</div>
      <div class="value">{{customer}}</div>
    </div>
    <div class="field">
      <div class="label">Fleet Size</div>
      <div class="value">{{vehicleCount}} vehicles</div>
    </div>
  </div>

  <!-- Fleet Summary -->
  <div class="section">
    <div class="section-title">Fleet Summary</div>
    <div class="metric-grid">
      <div class="metric-card">
        <div class="metric-label">Total Downtime</div>
        <div class="metric-value">{{summary.totalDowntimeDays}}</div>
        <div class="metric-unit">days ({{summary.totalDowntimeHours}} hrs)</div>
      </div>
      <div class="metric-card {{#if summary.totalCBJ}}danger{{/if}}">
        <div class="metric-label">Total CBJ</div>
        <div class="metric-value">{{summary.totalCBJ}}</div>
        <div class="metric-unit">comeback jobs</div>
      </div>
      <div class="metric-card">
        <div class="metric-label">Total Breakdown</div>
        <div class="metric-value">{{summary.totalBreakdown}}</div>
        <div class="metric-unit">incidents</div>
      </div>
      <div class="metric-card">
        <div class="metric-label">Services Performed</div>
        <div class="metric-value">{{summary.totalServiceCount}}</div>
        <div class="metric-unit">across fleet</div>
      </div>
      <div class="metric-card">
        <div class="metric-label">Repairs Performed</div>
        <div class="metric-value">{{summary.totalRepairCount}}</div>
        <div class="metric-unit">across fleet</div>
      </div>
      <div class="metric-card danger">
        <div class="metric-label">Total Cost</div>
        <div class="metric-value">${{formatMoney summary.totalCost}}</div>
        <div class="metric-unit">labor ${{formatMoney summary.totalLaborCost}} + material ${{formatMoney summary.totalMaterialCost}}</div>
      </div>
      <div class="metric-card">
        <div class="metric-label">Avg Cost / KM</div>
        <div class="metric-value">{{#if summary.avgCostPerKm}}${{formatMoney summary.avgCostPerKm}}{{else}}N/A{{/if}}</div>
      </div>
      <div class="metric-card {{#if summary.overdueVehicles.length}}warning{{else}}success{{/if}}">
        <div class="metric-label">Overdue Vehicles</div>
        <div class="metric-value">{{summary.overdueVehicles.length}}</div>
        <div class="metric-unit">of {{vehicleCount}}</div>
      </div>
    </div>
  </div>

  {{#if summary.worstDowntime}}
  <div class="section">
    <div class="section-title">Attention Required</div>
    <table>
      <tr>
        <th>Flag</th>
        <th>Vehicle</th>
        <th>Details</th>
      </tr>
      {{#if summary.worstDowntime.days}}
      <tr>
        <td>Highest Downtime</td>
        <td><strong>{{summary.worstDowntime.assetnum}}</strong></td>
        <td>{{summary.worstDowntime.days}} days ({{summary.worstDowntime.hours}} hrs)</td>
      </tr>
      {{/if}}
      {{#if summary.worstCBJ.count}}
      <tr>
        <td>Most Comeback Jobs</td>
        <td><strong>{{summary.worstCBJ.assetnum}}</strong></td>
        <td>{{summary.worstCBJ.count}} CBJs</td>
      </tr>
      {{/if}}
      {{#each summary.overdueVehicles}}
      <tr class="highlight">
        <td>Service Overdue</td>
        <td><strong>{{this}}</strong></td>
        <td><span class="status-badge status-overdue">OVERDUE</span></td>
      </tr>
      {{/each}}
    </table>
  </div>
  {{/if}}

  <!-- Per-Vehicle Breakdown -->
  <div class="section">
    <div class="section-title">Vehicle Breakdown</div>
    <table>
      <tr>
        <th>Vehicle #</th>
        <th>Description</th>
        <th>Downtime</th>
        <th>CBJ</th>
        <th>Breakdown</th>
        <th>Services</th>
        <th>Repairs</th>
        <th>Total Cost</th>
        <th>Schedule</th>
      </tr>
      {{#each vehicles}}
      <tr>
        <td><strong>{{#if this.vehicle.vehicleNo}}{{this.vehicle.vehicleNo}}{{else}}{{this.vehicle.assetnum}}{{/if}}</strong></td>
        <td>{{this.vehicle.description}}</td>
        <td>{{this.parameters.downtimeDays}}d <span style="color:#999;font-size:9px;">({{this.parameters.downtimeHours}}h)</span></td>
        <td>{{this.parameters.cbjCount}}</td>
        <td>{{this.parameters.breakdownCount}}</td>
        <td>{{this.maintenance.serviceCount}}</td>
        <td>{{this.maintenance.repairCount}}</td>
        <td>${{formatMoney this.spending.totalCost}}</td>
        <td>
          {{#if this.schedule.serviceOverdue}}
            <span class="status-badge status-overdue">OVERDUE</span>
          {{else}}
            <span class="status-badge status-ok">OK</span>
          {{/if}}
        </td>
      </tr>
      {{/each}}
    </table>
  </div>

  <div class="footer">
    Generated on {{formatDateTime generatedAt}} &bull; Goldbell Engineering Services &bull; Confidential
  </div>

</body>
</html>
