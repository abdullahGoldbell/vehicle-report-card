<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      font-size: 11px;
      color: #1a1a2e;
      background: #fff;
      padding: 30px 40px;
    }

    .header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-bottom: 3px solid #C8A951;
      padding-bottom: 15px;
      margin-bottom: 20px;
    }
    .header h1 {
      font-size: 22px;
      color: #003366;
      font-weight: 700;
    }
    .header .subtitle {
      font-size: 11px;
      color: #666;
      margin-top: 4px;
    }
    .header .logo {
      text-align: right;
    }
    .header .logo .brand {
      font-size: 18px;
      font-weight: 700;
      color: #C8A951;
    }
    .header .logo .brand-sub {
      font-size: 9px;
      color: #003366;
      font-weight: 600;
    }

    .vehicle-info {
      background: #F5F2EB;
      border-radius: 8px;
      padding: 14px 20px;
      margin-bottom: 20px;
      display: flex;
      gap: 40px;
      flex-wrap: wrap;
    }
    .vehicle-info .label {
      font-size: 9px;
      text-transform: uppercase;
      color: #666;
      letter-spacing: 0.5px;
    }
    .vehicle-info .value {
      font-size: 13px;
      font-weight: 600;
      color: #003366;
    }

    .section {
      margin-bottom: 18px;
      page-break-inside: avoid;
    }
    .section-title {
      font-size: 13px;
      font-weight: 700;
      color: #003366;
      border-left: 4px solid #C8A951;
      padding-left: 10px;
      margin-bottom: 10px;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 8px;
    }
    th {
      background: #003366;
      color: #fff;
      padding: 7px 10px;
      text-align: left;
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    td {
      padding: 6px 10px;
      border-bottom: 1px solid #e8ecf1;
      font-size: 11px;
    }
    tr:nth-child(even) { background: #f8f9fc; }

    .metric-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 10px;
    }
    .metric-card {
      background: #f8f9fc;
      border-radius: 6px;
      padding: 12px 14px;
      border-left: 3px solid #003366;
    }
    .metric-card .metric-label {
      font-size: 9px;
      text-transform: uppercase;
      color: #666;
      letter-spacing: 0.3px;
    }
    .metric-card .metric-value {
      font-size: 20px;
      font-weight: 700;
      color: #003366;
      margin-top: 2px;
    }
    .metric-card .metric-unit {
      font-size: 9px;
      color: #999;
    }
    .metric-card.warning { border-left-color: #C8A951; }
    .metric-card.danger { border-left-color: #E5004B; }
    .metric-card.success { border-left-color: #2ecc71; }

    .status-badge {
      display: inline-block;
      padding: 2px 8px;
      border-radius: 10px;
      font-size: 9px;
      font-weight: 600;
      text-transform: uppercase;
    }
    .status-overdue { background: #fde8ec; color: #E5004B; }
    .status-ok { background: #e8f8f0; color: #2ecc71; }
    .status-open { background: #FFF8E1; color: #C8A951; }

    .cost-summary {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 10px;
    }

    .footer {
      margin-top: 30px;
      padding-top: 10px;
      border-top: 1px solid #C8A951;
      font-size: 9px;
      color: #999;
      text-align: center;
    }

    .no-data { color: #999; font-style: italic; }
  </style>
</head>
<body>

  <div class="header">
    <div>
      <h1>Vehicle Performance Report</h1>
      <div class="subtitle">
        Reporting Period: {{formatDate period.startDate}} — {{formatDate period.endDate}}
      </div>
    </div>
    <div class="logo">
      <div class="brand">GOLDBELL</div>
      <div class="brand-sub">Engineering Services</div>
    </div>
  </div>

  <div class="vehicle-info">
    <div class="field">
      <div class="label">Vehicle Number</div>
      <div class="value">{{#if vehicle.vehicleNo}}{{vehicle.vehicleNo}}{{else}}{{vehicle.assetnum}}{{/if}}</div>
    </div>
    <div class="field">
      <div class="label">Chassis Number</div>
      <div class="value">{{vehicle.assetnum}}</div>
    </div>
    <div class="field">
      <div class="label">Description</div>
      <div class="value">{{vehicle.description}}</div>
    </div>
    <div class="field">
      <div class="label">Customer</div>
      <div class="value">{{vehicle.customerName}}</div>
    </div>
    <div class="field">
      <div class="label">Agreement</div>
      <div class="value">{{vehicle.agreement}}</div>
    </div>
  </div>

  <!-- Section A: Performance Parameters -->
  <div class="section">
    <div class="section-title">A. Performance Parameters</div>
    <div class="metric-grid">
      <div class="metric-card">
        <div class="metric-label">Vehicle Downtime</div>
        <div class="metric-value">{{parameters.downtimeDays}}</div>
        <div class="metric-unit">days ({{parameters.downtimeHours}} hrs)</div>
      </div>
      <div class="metric-card {{countClass parameters.cbjCount}}">
        <div class="metric-label">Comeback Jobs (CBJ)</div>
        <div class="metric-value">{{parameters.cbjCount}}</div>
        <div class="metric-unit">incidents</div>
      </div>
      <div class="metric-card {{countClass parameters.breakdownCount}}">
        <div class="metric-label">Breakdown</div>
        <div class="metric-value">{{parameters.breakdownCount}}</div>
        <div class="metric-unit">incidents</div>
      </div>
      <div class="metric-card">
        <div class="metric-label">Warranty Repairs</div>
        <div class="metric-value">{{parameters.warrantyRepairCount}}</div>
        <div class="metric-unit">internal jobs</div>
      </div>
      <div class="metric-card">
        <div class="metric-label">Avg Waiting Time</div>
        <div class="metric-value">{{parameters.avgWaitingHours}}</div>
        <div class="metric-unit">hours</div>
      </div>
    </div>
  </div>

  <!-- Section B: Vehicle Maintenance -->
  <div class="section">
    <div class="section-title">B. Vehicle Maintenance</div>
    <table>
      <tr>
        <th>Metric</th>
        <th>Value</th>
      </tr>
      <tr>
        <td>Service Count</td>
        <td><strong>{{maintenance.serviceCount}}</strong></td>
      </tr>
      <tr>
        <td>Last Service Date</td>
        <td>{{#if maintenance.lastServiceDate}}{{formatDate maintenance.lastServiceDate}}{{else}}<span class="no-data">No record</span>{{/if}}</td>
      </tr>
      <tr>
        <td>Repair Count</td>
        <td><strong>{{maintenance.repairCount}}</strong></td>
      </tr>
      <tr>
        <td>Last Repair Date</td>
        <td>{{#if maintenance.lastRepairDate}}{{formatDate maintenance.lastRepairDate}}{{else}}<span class="no-data">No record</span>{{/if}}</td>
      </tr>
    </table>

    {{#if maintenance.outstandingJobs.length}}
    <div style="margin-top: 8px; font-weight: 600; font-size: 11px; color: #003366;">Outstanding Jobs</div>
    <table>
      <tr>
        <th>WO Number</th>
        <th>Description</th>
        <th>Type</th>
        <th>Status</th>
        <th>Reported</th>
      </tr>
      {{#each maintenance.outstandingJobs}}
      <tr>
        <td>{{this.wonum}}</td>
        <td>{{this.description}}</td>
        <td>{{this.worktype}}</td>
        <td><span class="status-badge status-open">{{this.status}}</span></td>
        <td>{{formatDate this.reportdate}}</td>
      </tr>
      {{/each}}
    </table>
    {{/if}}

    {{#if maintenance.outstandingRecalls.length}}
    <div style="margin-top: 8px; font-weight: 600; font-size: 11px; color: #003366;">Outstanding Recalls</div>
    <table>
      <tr>
        <th>Recall #</th>
        <th>Campaign</th>
        <th>Status</th>
      </tr>
      {{#each maintenance.outstandingRecalls}}
      <tr>
        <td>{{this.recallnumber}}</td>
        <td>{{this.campaigncode}}</td>
        <td><span class="status-badge status-open">{{this.campaignstatus}}</span></td>
      </tr>
      {{/each}}
    </table>
    {{/if}}
  </div>

  <!-- Section C: Vehicle Schedule -->
  <div class="section">
    <div class="section-title">C. Vehicle Schedule</div>
    <table>
      <tr>
        <th>Service Overdue</th>
        <th>Next Service Date</th>
      </tr>
      <tr>
        <td>
          {{#if schedule.serviceOverdue}}
            <span class="status-badge status-overdue">OVERDUE</span>
          {{else}}
            <span class="status-badge status-ok">OK</span>
          {{/if}}
        </td>
        <td>{{#if schedule.nextServiceDate}}{{formatDate schedule.nextServiceDate}}{{else}}<span class="no-data">Not scheduled</span>{{/if}}</td>
      </tr>
    </table>

    {{#if schedule.pmDetails.length}}
    <div style="margin-top: 8px; font-weight: 600; font-size: 11px; color: #003366;">PM Schedule</div>
    <table>
      <tr>
        <th>PM #</th>
        <th>Service Pkg</th>
        <th>WO #</th>
        <th>WO Status</th>
        <th>Last Completed</th>
        <th>Next Due Date</th>
        <th>Mileage</th>
        <th>Expiry</th>
        <th>Status</th>
      </tr>
      {{#each schedule.pmDetails}}
      <tr>
        <td>{{this.pmnum}}</td>
        <td>{{this.servicePkgType}}</td>
        <td>{{#if this.wonum}}{{this.wonum}}{{else}}—{{/if}}</td>
        <td>{{#if this.woStatus}}<span class="status-badge status-open">{{this.woStatus}}</span>{{else}}—{{/if}}</td>
        <td>{{#if this.lastCompDate}}{{formatDate this.lastCompDate}}{{else}}—{{/if}}</td>
        <td>{{#if this.nextDueDate}}{{formatDate this.nextDueDate}}{{else}}—{{/if}}</td>
        <td>{{#if this.mileageReading}}{{this.mileageReading}}{{else}}—{{/if}}</td>
        <td>{{#if this.expiryDate}}{{formatDate this.expiryDate}}{{else}}—{{/if}}</td>
        <td>
          {{#if this.isOverdue}}
            <span class="status-badge status-overdue">OVERDUE</span>
          {{else}}
            <span class="status-badge status-ok">OK</span>
          {{/if}}
        </td>
      </tr>
      {{/each}}
    </table>
    {{/if}}
  </div>

  <!-- Section D: Parts Entitlement -->
  <div class="section">
    <div class="section-title">D. Parts Entitlement</div>
    {{#if entitlements.length}}
    <table>
      <tr>
        <th>Agreement</th>
        <th>Ops Code</th>
        <th>Description</th>
        <th>Total Qty</th>
        <th>Used</th>
        <th>Balance</th>
        <th>Period</th>
      </tr>
      {{#each entitlements}}
      <tr>
        <td>{{this.agreement}}</td>
        <td>{{this.opsCode}}</td>
        <td>{{this.opsDesc}}</td>
        <td>{{this.quantity}}</td>
        <td>{{this.usedQty}}</td>
        <td><strong>{{this.balanceQty}}</strong></td>
        <td style="font-size: 9px;">{{formatDate this.startDate}} — {{formatDate this.endDate}}</td>
      </tr>
      {{/each}}
    </table>
    {{else}}
    <p class="no-data">No entitlement data available.</p>
    {{/if}}
  </div>

  <!-- Section E: Customer Spending -->
  <div class="section">
    <div class="section-title">E. Customer Spending</div>
    <div class="cost-summary">
      <div class="metric-card">
        <div class="metric-label">Labor Cost</div>
        <div class="metric-value">${{formatMoney spending.laborCost}}</div>
      </div>
      <div class="metric-card">
        <div class="metric-label">Material Cost</div>
        <div class="metric-value">${{formatMoney spending.materialCost}}</div>
      </div>
      <div class="metric-card">
        <div class="metric-label">Total Cost</div>
        <div class="metric-value" style="color: #E5004B;">${{formatMoney spending.totalCost}}</div>
      </div>
      <div class="metric-card">
        <div class="metric-label">Cost / KM</div>
        <div class="metric-value">{{#if spending.costPerKm}}${{formatMoney spending.costPerKm}}{{else}}<span style="font-size: 12px;" class="no-data">N/A</span>{{/if}}</div>
        {{#if spending.mileageDelta}}<div class="metric-unit">{{spending.mileageDelta}} km in period</div>{{/if}}
      </div>
    </div>
  </div>

  <div class="footer">
    Generated on {{formatDateTime generatedAt}} &bull; Goldbell Engineering Services &bull; Confidential
  </div>

</body>
</html>
